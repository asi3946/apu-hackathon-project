                    isBookmarked 
                      ? "bg-yellow-50 text-yellow-600 border-yellow-200 hover:bg-yellow-100" 
                      : "bg-white text-gray-500 border-gray-200 hover:bg-gray-50 hover:text-gray-700"
                  )}
                >
                  <Bookmark className={cn("w-4 h-4", isBookmarked && "fill-current")} />
